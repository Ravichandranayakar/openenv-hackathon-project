{
  "terminal.integrated.shell.windows": "pwsh",
  "terminal.integrated.shellArgs.windows": ["-NoProfile"],
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "args": ["-NoExit", "-Command", "& {$profile = $PROFILE.CurrentUserCurrentHost; if (Test-Path $profile) { & $profile }}"]
    }
  },
  "terminal.integrated.defaultProfile.windows": "PowerShell"
}
